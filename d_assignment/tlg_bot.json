              "message": "=Extract also the chat_id of the client\nfrom: {{ $json.message.from.id }}\n\n"
            },
            {
              "message": "=Extract all details as JSON FROMAT,\n{\n\"booking_id\": \"value\",\nstring(extracted_number)\n\"event\":\"reservation\" or \"cancellation\",\n\"name:\"value\",\n\"chat_id\": \"value\"\n}\nif you did not find specific detail \nmetioned, return null in value instead."
            }
          ]
        },
